+    def _sanitise_non_finite_grads(self) -> int:
+        """Replace NaN/+inf/-inf gradient elements with 0.
+
+        ``torch.nn.utils.clip_grad_norm_`` does not sanitise non-finite
+        gradients: if any grad is NaN, the global norm becomes NaN, the
+        clip coefficient becomes NaN, and ``grad *= NaN`` leaves the grad
+        NaN. The subsequent ``optimizer.step()`` then writes NaN into
+        every parameter. This method prevents that by zeroing non-finite
+        elements before clip_grad_norm_ runs — a bad mini-batch
+        degenerates to a no-op update instead of corrupting weights.
+
+        The check is a no-op on clean training paths: ``nan_to_num_`` of
+        a finite tensor is identity. Returns the number of sanitised
+        elements so callers can surface a metric.
+        """
+        fixed = 0
+        for p in self.actor_critic.parameters():
+            if p.grad is None:
+                continue
+            bad = ~torch.isfinite(p.grad)
+            if bad.any():
+                fixed += int(bad.sum().item())
+                torch.nan_to_num_(p.grad, nan=0.0, posinf=0.0, neginf=0.0)
+        return fixed
+
