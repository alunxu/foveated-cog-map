# --- Private cluster (RCP) artefacts ----------------------------------------
# Public submission scripts (Izar SLURM, generic utilities) live in
# scripts/cluster/. RCP-specific submission scripts (runai-rcp-prod calls,
# hard-coded /scratch/wxu/ paths, kubectl namespaces) are kept private
# under scripts/cluster_rcp/ because they depend on a private K8s/RunAI
# cluster the teammate + course infrastructure don't have access to.

docker/build_with_kaniko.sh
scripts/cluster_rcp/
scripts/probing/lagk_rcp.sh
scripts/probing/mlp_rcp.sh
